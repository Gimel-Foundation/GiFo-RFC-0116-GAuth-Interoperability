Appendix F: Claims Enrichment Hook (Reference Implementation)
===============================================================

F.1 Before Hook — Pre-Issuance Validation (Pseudocode)
--------------------------------------------------------

.. code-block:: text

  function before_token_hook(oauth_request):
      subject = oauth_request.subject

      // 1. Look up the active PoA for this subject
      poa = lookup_active_poa(subject)
      if poa is null:
          return { allow: false, error: "NO_ACTIVE_POA" }

      // 2. Evaluate policy: does the PoA permit token issuance?
      decision = evaluate_policy(subject, "token_issuance", poa)
      if not decision.allowed:
          return { allow: false, error: decision.reason }

      // 3. Pass the PoA to the after hook via context
      return { allow: true, context: { poa: poa } }

F.2 After Hook — Claims Injection (Pseudocode)
------------------------------------------------

.. code-block:: text

  function after_token_hook(oauth_request, context):
      poa = context.poa

      // 1. Build gauth claims from the canonical PoA schema
      gauth_claims = {
          version: CURRENT_SPEC_VERSION,
          credential_id: poa.credential_id,
          customer_id: poa.customer_id,
          project_id: poa.project_id,
          scope: {
              governance_profile: poa.scope.governance_profile,
              active_modules: poa.scope.active_modules,
              phase: poa.scope.phase,
              allowed_paths: poa.scope.allowed_paths,
              denied_paths: poa.scope.denied_paths
          },
          scope_checksum: compute_scope_checksum(poa),
          tool_permissions_hash:
              sha256(canonical_json(poa.scope.core_verbs)),
          platform_permissions_hash:
              sha256(canonical_json(poa.scope.platform_permissions)),
          issued_by: poa.parties.issued_by,
          approval_mode: poa.requirements.approval_mode
      }

      // 2. Build mandate claims if a mandate is active
      mandate_claims = null
      if poa.mandate is not null:
          mandate_claims = {
              mandate_id: poa.mandate.id,
              mandate_status: poa.mandate.status,
              budget: poa.mandate.budget,
              session: poa.mandate.session,
              agent_capability_hash:
                  sha256(canonical_json(poa.mandate.capabilities))
          }

      // 3. Return enriched claims for the OAuth engine to
      //    include in the signed JWT
      extra_claims = { gauth: gauth_claims }
      if mandate_claims is not null:
          extra_claims.gauth_mandate = mandate_claims

      return { extra_claims: extra_claims }

